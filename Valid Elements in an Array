class Solution {
public:
    vector<int> findValidElements(vector<int>& nums) {
        int n=nums.size();
        if (n==0 || n==1) {
            return nums;
        }
        vector<int> prefMaxNums(n);
        vector<int> suffMaxNums(n);
        for (int i=0; i<n; i++) {
            prefMaxNums[i]=nums[i];
            suffMaxNums[i]=nums[i];
        }
        prefMaxNums[0]=nums[0];
        suffMaxNums[n-1]=nums[n-1];
        for (int i=1; i<n; i++) {
            prefMaxNums[i]=max(prefMaxNums[i-1],nums[i]);
        }
        for (int i=n-2; i>=0; i--) {
            suffMaxNums[i]=max(suffMaxNums[i+1],nums[i]);
        }
        vector<int> validElements;
        validElements.push_back(nums[0]);
        for (int i=1; i<n-1; i++) {
            if (nums[i]>prefMaxNums[i-1] || nums[i]>suffMaxNums[i+1]) {
                validElements.push_back(nums[i]);
            }
        }
        validElements.push_back(nums[n-1]);
        return validElements;
    }
};
